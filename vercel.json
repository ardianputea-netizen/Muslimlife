{
  "rewrites": [
    {
      "source": "/api/quran/chapters",
      "destination": "/api/quran?route=chapters"
    },
    {
      "source": "/api/quran/surah",
      "destination": "/api/quran?route=surah"
    },
    {
      "source": "/api/dua-dhikr/categories",
      "destination": "/api/dua-dhikr?route=categories"
    },
    {
      "source": "/api/dua-dhikr/categories/:category/:id",
      "destination": "/api/dua-dhikr?route=category-detail&category=:category&id=:id"
    },
    {
      "source": "/api/dua-dhikr/categories/:category",
      "destination": "/api/dua-dhikr?route=category-items&category=:category"
    },
    {
      "source": "/api/dua-dhikr/:slug*",
      "destination": "/api/dua-dhikr?route=passthrough&slug=:slug*"
    },
    {
      "source": "/api/asmaul-husna",
      "destination": "/api/content?route=asmaul-husna"
    },
    {
      "source": "/api/tahlil",
      "destination": "/api/content?route=tahlil"
    },
    {
      "source": "/api/rating",
      "destination": "/api/weather?ml_route=rating"
    },
    {
      "source": "/api/push-subscribe",
      "destination": "/api/weather?ml_route=push-subscribe"
    },
    {
      "source": "/api/push-unsubscribe",
      "destination": "/api/weather?ml_route=push-unsubscribe"
    },
    {
      "source": "/api/yasin",
      "destination": "/api/quran?route=surah&chapterId=36"
    },
    {
      "source": "/((?!api(?:/|$))(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/push-reminders",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(self), camera=(), microphone=(), payment=(), usb=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss: https://cdn.equran.id; media-src 'self' data: blob: https://download.quranicaudio.com https://audio.qurancdn.com https://verses.quran.com https://cdn.equran.id; frame-src 'self' https://form.typeform.com https://*.typeform.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; worker-src 'self' blob:;"
        }
      ]
    }
  ]
}
